SECRET_KEY=change_me_to_a_random_string

# Casdoor SSO（必填）
CASDOOR_ENDPOINT=https://auth.example.com
CASDOOR_CLIENT_ID=your-client-id
CASDOOR_CLIENT_SECRET=your-client-secret
# Casdoor 应用的 JWT 证书（在 Casdoor 管理后台 → 应用 → 证书 中找到，复制 PEM 内容）
CASDOOR_CERTIFICATE=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
CASDOOR_ORG_NAME=your-org-name
CASDOOR_APP_NAME=your-app-name

# 数据库（默认 SQLite，开箱即用）
# DB_BACKEND=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=thccb
# MYSQL_PASSWORD=change_me
# MYSQL_DB=thccb

# 游戏初始余额
INITIAL_BALANCE=100.0

# ========================================
# TouhouCCB 后端环境变量
# 复制为 .env 并填入实际值
# ========================================

# --- 环境 ---
APP_ENV=development                              # "development" | "production"，生产环境将强制校验密钥配置

# --- 安全 ---
SECRET_KEY=change_me_to_a_random_string         # JWT 签名密钥，至少 32 字符（生产环境必填）
ADMIN_PASSWORD_HASH=                             # bcrypt hash，生成方式：python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_SECRET_KEY=                                # Admin 面板 session 密钥，留空自动生成

# --- Casdoor SSO（通过 .well-known 自动发现，无需手动配证书）---
CASDOOR_ENDPOINT=https://auth.example.com
CASDOOR_CLIENT_ID=your-client-id
CASDOOR_CLIENT_SECRET=your-client-secret
CASDOOR_ORG_NAME=your-org-name
CASDOOR_APP_NAME=your-app-name

# --- 数据库 ---
# Docker Compose 默认使用 PostgreSQL（推荐）
DB_BACKEND=postgres
PG_HOST=postgres
PG_PORT=5432
PG_USER=thccb
PG_PASSWORD=change_me
PG_DB=thccb

# SQLite（本地开发用，无需额外服务）
# DB_BACKEND=sqlite
# SQLITE_PATH=data/thccb.db

# MySQL
# DB_BACKEND=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=thccb
# MYSQL_PASSWORD=change_me
# MYSQL_DB=thccb

# --- CORS（生产环境改成你的域名）---
CORS_ORIGINS=https://thccb.example.com

# --- 游戏 ---
INITIAL_BALANCE=100.0
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

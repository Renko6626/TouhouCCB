# ========================================
# TouhouCCB 环境变量（唯一配置文件）
# 复制为 .env 并填入实际值
#
# docker-compose.yml 和后端应用都从这一个文件读取，
# 不需要在 backend/ 下再建 .env。
# ========================================

# --- 环境 ---
APP_ENV=development                              # "development" | "production"

# --- Docker ---
UID=1007                                         # 容器内用户 UID（id -u 查看）
GID=1008                                         # 容器内用户 GID（id -g 查看）

# --- 安全 ---
SECRET_KEY=change_me_to_a_random_string         # JWT 签名密钥，至少 32 字符
ADMIN_SECRET_KEY=                                # Admin 面板 session 密钥，留空自动生成

# --- Casdoor SSO（后端只需这 3 项）---
CASDOOR_ENDPOINT=https://auth.example.com
CASDOOR_CLIENT_ID=your-client-id
CASDOOR_CLIENT_SECRET=your-client-secret

# --- 前端 URL（用于 OAuth redirect_uri）---
FRONTEND_URL=http://localhost:5173

# --- 数据库（PostgreSQL，Docker Compose 默认）---
DB_BACKEND=postgres
PG_HOST=postgres
PG_PORT=5432
PG_USER=thccb
PG_PASSWORD=change_me
PG_DB=thccb

# SQLite（本地开发用，无需额外服务）
# DB_BACKEND=sqlite
# SQLITE_PATH=data/thccb.db

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- 游戏 ---
INITIAL_BALANCE=100.0
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

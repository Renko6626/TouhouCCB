# ========================================
# TouhouCCB 前端环境变量
# 开发环境直接用，生产构建前改 .env.production
# ========================================

# 后端 API 地址
VITE_API_BASE_URL=http://localhost:8004

# 应用标题
VITE_APP_TITLE=东方炒炒币

# Casdoor SSO（必填）
VITE_CASDOOR_URL=https://auth.example.com
VITE_CASDOOR_CLIENT_ID=your-client-id
VITE_CASDOOR_ORG=your-org-name
VITE_CASDOOR_APP=your-app-name
